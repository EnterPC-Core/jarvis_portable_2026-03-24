{
  "name": "jarvis-ai-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 execute jarvis_ai_db --local --file=./sql/schema.sql",
    "db:migrate:remote": "wrangler d1 execute jarvis_ai_db --remote --file=./sql/schema.sql",
    "local:bot": "node local/termux-bot.mjs",
    "local:check": "node --check local/termux-bot.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "^5.8.2",
    "wrangler": "^4.8.0"
  }
}
